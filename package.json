{
  "name": "guitar-chords-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "browser-app": "vite preview --host 127.0.0.1 --port 4173 --strictPort --open",
    "desktop": "electron .",
    "build:desktop": "npm run build && electron-packager . \"Guitar Chords Editor\" --platform=win32 --arch=x64 --out=release --overwrite --prune=true"
  },
  "devDependencies": {
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.omri.guitarchordseditor",
    "productName": "Guitar Chords Editor",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
